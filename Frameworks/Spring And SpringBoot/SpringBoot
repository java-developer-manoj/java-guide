@Aspect
@Component
@S1f4j
public class LogExecutionTracker {

@Around("@annotation(com.javatechie.annotation.TrackExecutionTime)")
public Object logExecutionDuration(ProceedingJoinPoint pjp) throws Throwable {

//before advice

long startTime = System. currentTimeMillisO;
Object obj = pjp.proceedO;

//after advice

long endTime = System. currentTimeMillis;
log. info(" method {} execution takes {} ms times to complete ", pjp.getSignatureO, (endTime-startTime));

return obj;

  }
}


