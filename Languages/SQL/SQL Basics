# ROLLUP and CUBE
=================

# ROLLUP
---------
=> Rollup is used to get the grand total and sub total of each department only ;

Q)Grand total only

Ans) select emp_department_number as department,sum(emp_salary) from employee group by rollup(emp_department_number)

Q)Subtotal with Grand total of each department

Ans) 

SELECT 
    emp_department_number AS department,
    designation,
    SUM(emp_salary) AS total_salary,
FROM employee
GROUP BY ROLLUP(emp_department_number, designation)
ORDER BY department NULLS LAST;

Extra Naming if we want for sub totals and grand totals:
--------------------------------------------------------

SELECT 
    emp_department_number AS department,
    designation,
    SUM(emp_salary) AS total_salary,
    CASE
        WHEN GROUPING(emp_department_number) = 0 
             AND GROUPING(designation) = 1 
            THEN 'Dept Sub Total'
        WHEN GROUPING(emp_department_number) = 1 
             AND GROUPING(designation) = 1 
            THEN 'Grand Total'
    END AS sub_totals
FROM employee
GROUP BY ROLLUP(emp_department_number, designation)
ORDER BY department NULLS LAST;



# CUBE
-------

=> Cube is also used to get the grand total and sub total of each department and designation 

Q)Grand total only

Ans) select emp_department_number as department,sum(emp_salary) from employee group by cube(emp_department_number)

Q)Subtotal with Grand total of each department and designation

Ans)

SELECT 
    emp_department_number AS department,
    designation,
   
FROM employee
GROUP BY CUBE(emp_department_number, designation)
ORDER BY department NULLS FIRST;

Extra Naming if we want for sub totals and grand totals:
-------------------------------------------------------

select emp_department_number as department ,designation,
sum(emp_salary), case when grouping(emp_department_number)=0
                     and grouping(designation)=1 then 'Dept Sub Total'
					 
					 when grouping(emp_department_number)=1
                     and grouping(designation)=0 then 'Designation Sub Total'
					 
					 when grouping(emp_department_number)=1
                     and grouping(designation)=1 then 'Grand Total' end as sub_totals	
					 from employee
group by CUBE(emp_department_number,designation) order by 1 nulls last




