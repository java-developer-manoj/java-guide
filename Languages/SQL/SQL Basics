# QUERIES

## CREATE DATABASE

```sql id="0m8iqc"
create database learning_postgres;
```

## CREATE TABLE

```sql id="o0j4gi"
create table student(
student_id int primary key,
student_name varchar(100) not null,
student_group varchar(100),
student_age int check(student_age > 3),
student_gender char(1)
);
```

## ADD COLUMN

```sql id="vy6r8o"
alter table student add column student_email varchar(100);
```

## RENAME COLUMN

```sql id="knq9e5"
alter table student rename column student_email to student_gmail;
```

## DROP COLUMN

```sql id="trh1ye"
alter table student drop column student_gmail;
```

## INSERT DATA

```sql id="5snx3m"
insert into student values
(1,'Manoj','BSC',23,'M'),
(2,'Arun','BTECH',27,'M');
```

## SELECT ALL

```sql id="nb02n1"
select * from student;
```

## UPDATE DATA

```sql id="b2y1o7"
update student set student_age = 30 where student_id = 1;
```

## DELETE ONE RECORD

```sql id="46x2gl"
delete from student where student_id = 1;
```

## DELETE ALL RECORDS

```sql id="1syx2x"
delete from student;
```

## SELECT SPECIFIC COLUMNS

```sql id="fx5qsh"
select student_id, student_name from student;
```

## ORDER BY

```sql id="u9h5o2"
select * from student order by student_age asc;
select * from student order by student_age desc;
```

## DISTINCT

```sql id="e5p0vd"
select distinct student_name from student;
```

## COUNT

```sql id="qgl2g5"
select count(*) from student;
```

## AVERAGE

```sql id="drjqm2"
select avg(student_age) as average_age from student;
```

## MINIMUM

```sql id="uyw32g"
select min(student_age) as minimum_age from student;
```

## MAXIMUM

```sql id="1nj1kj"
select max(student_age) as maximum_age from student;
```

## SUM

```sql id="v3d4dx"
select sum(student_age) as sum_age from student;
```

